# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Supabase Session Pooler connection string (port 5432, IPv4-compatible)
# Format: postgresql+psycopg://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# LLM provider (only 'anthropic' is supported)
LLM_PROVIDER=anthropic

# Anthropic model identifier
LLM_MODEL=claude-sonnet-4-6

# Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
